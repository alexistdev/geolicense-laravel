# Template .env untuk PRODUCTION (geolicense-laravel).
# Salin ke .env di server:  cp deploy/env.production.example .env
# Lalu:
#   php artisan key:generate                         # mengisi APP_KEY
#   ganti GEOLICENSE_TOKEN_SECRET dengan nilai acak baru (WAJIB — lihat catatan bawah)
#     contoh generate:  openssl rand -hex 32
#   isi DB_PASSWORD dengan password kuat yang sama seperti di MySQL.

APP_NAME=GeoLicense
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://geolicense.my.id

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=geolicense_laravel
DB_USERNAME=geolicense
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Semua pakai driver database — tidak perlu Redis untuk skala awal.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Set ke domain agar cookie sesi konsisten (opsional). Contoh: .geolicense.my.id
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

# Redis tidak dipakai (disimpan untuk referensi bila nanti diaktifkan).
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Belum kirim email betulan — tulis ke log. Ganti ke SMTP (Brevo/Mailgun) saat perlu.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@geolicense.my.id"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =====================================================================
# GeoLicense — secret token aktivasi lisensi (HMAC-SHA256).
# WAJIB DIGANTI di production. Nilai contoh yang ada di .env.example bersifat
# publik; kalau dipakai apa adanya, token lisensi bisa dipalsukan pihak lain.
# Generate baru:  openssl rand -hex 32
# =====================================================================
GEOLICENSE_TOKEN_SECRET=GANTI_DENGAN_HASIL_openssl_rand_hex_32
GEOLICENSE_TOKEN_EXPIRATION=86400000
